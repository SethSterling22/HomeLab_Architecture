# ansible/inventory/group_vars/all.yml
# NEVER commit this file — it contains secrets.
# Copy from all.yml.example and fill in the real values.
---

# ── Tailscale ────────────────────────────────────────────────────
tailscale_auth_key: "tskey-auth-XXXXXXXXXXXXXXXX"  # https://login.tailscale.com/admin/settings/keys
tailscale_subnet_route: "192.168.68.0/24"

# ── k3s ─────────────────────────────────────────────────────────
k3s_version: "v1.35.5+k3s1"
k3s_token: "change-me-to-a-long-secure-token"   # openssl rand -hex 32

# ── Proxmox (Sadida host) ────────────────────────────────────────
# The k3s master and Ollama run directly on this host — no guest VMs.
proxmox_api_host: "192.168.68.10"
proxmox_api_user: "root@pam"
proxmox_api_token_id: "ansible"
proxmox_api_token_secret: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_node: "sadida"

# ── Aery NFS (Synology) ──────────────────────────────────────────
aery_nfs_server: "192.168.68.190"
aery_nfs_path: "/volume1/k3s"

# ── Ollama (local host service on Sadida, GPU) ───────────────────
ollama_host: "sadida.stegosaurus-panga.ts.net"
ollama_port: 11434
ollama_models:
  - "qwen3:1.7b"     # intent classifier
  - "qwen3.5:4b"     # main agent

# ── SSH ──────────────────────────────────────────────────────────
ssh_public_key: "ssh-ed25519 AAAA... you@machine"

# ── Wake-on-LAN ──────────────────────────────────────────────────
wol_broadcast: "192.168.68.255"
